# Mẫu cấu hình môi trường cho workshop.
# Bình thường bạn KHÔNG cần tạo file này thủ công — script pull_models.ps1/.sh
# sẽ tự sinh ra file `.env` (đã gitignore) theo model bạn chọn.
#
# Chỉ copy file này thành `.env` nếu muốn tự đặt model:  cp .env.example .env

# Model sinh câu trả lời (LLM). Đổi sang qwen3:4b / qwen3:8b nếu máy đủ mạnh.
LLM_MODEL=qwen3:1.7b

# Model tạo embedding cho RAG (Module 2). Đổi EMBED_MODEL nhớ build lại index.
EMBED_MODEL=nomic-embed-text

# Endpoint Ollama (tương thích OpenAI). Mặc định Ollama chạy ở cổng 11434.
OLLAMA_BASE_URL=http://localhost:11434/v1
