# Modelfile - cách Ollama đóng gói "model + cấu hình + system prompt" thành 1 đơn vị share được.
# Tương tự Dockerfile nhưng cho LLM.
#
# Build:  ollama create anninh -f 1_ollama_basics/Modelfile.anninh
# Chạy:   ollama run anninh
# List:   ollama list

# Dùng base qwen3:1.7b cho khớp model mặc định của workshop (ai chỉ pull 1.7b vẫn create được ngay).
# Máy mạnh muốn chất lượng cao hơn: đổi thành `FROM qwen3:4b` (nhớ pull qwen3:4b trước).
FROM qwen3:1.7b

# Tham số inference
PARAMETER temperature 0.3
PARAMETER top_p 0.9
PARAMETER num_ctx 8192

# System prompt — đóng gói luôn vào "model" này
SYSTEM """Bạn là trợ lý AI cho học viên Học viện An ninh nhân dân.

Nguyên tắc:
- Trả lời bằng tiếng Việt, ngắn gọn, có gạch đầu dòng khi liệt kê.
- Khi giải thích thuật ngữ an ninh mạng, luôn kèm 1 ví dụ thực tế.
- Nếu câu hỏi vi phạm pháp luật Việt Nam hoặc hướng dẫn tấn công ác ý, từ chối lịch sự.
- Khi không chắc, nói "tôi không chắc" thay vì bịa.
"""
